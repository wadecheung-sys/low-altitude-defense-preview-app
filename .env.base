# 环境
VITE_NODE_ENV=development

# 接口前缀
VITE_API_BASE_PATH=

# 打包路径
VITE_BASE_PATH=/

# 标题（浏览器标签等）
VITE_APP_TITLE=低空防御指挥控制平台
# 侧栏 Logo 短标题（一行展示）
VITE_APP_TITLE_SHORT=低空防御指挥控制平台

# 是否全量引入element-plus样式
VITE_USE_ALL_ELEMENT_PLUS_STYLE=true

# 是否开启mock
VITE_USE_MOCK=true

# 是否使用在线图标
VITE_USE_ONLINE_ICON=true

# 是否隐藏全局设置按钮（主题/布局抽屉）
VITE_HIDE_GLOBAL_SETTING=true

# 高德地图 JS API（区域管理 GIS 框选）https://console.amap.com/dev/key/app
VITE_AMAP_KEY=
# 若控制台为该 Key 配置了安全密钥，请填写（否则留空）
VITE_AMAP_SECURITY_CODE=
